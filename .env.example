# === Argus Configuration ===
# Copy to .env and uncomment/set values as needed.
# All variables have safe defaults — only API keys are required for paid providers.

# === App ===
# ARGUS_APP_HOST=0.0.0.0
# ARGUS_APP_PORT=8000
# ARGUS_APP_DEBUG=false
# ARGUS_APP_LOG_LEVEL=info

# === Redis ===
# ARGUS_REDIS_URL=redis://localhost:6379/0

# === SQLite ===
# ARGUS_SQLITE_PATH=~/.argus/knowledge.db
# ARGUS_SQLITE_WAL_MODE=true
# ARGUS_SQLITE_CACHE_SIZE=-64000

# === LLM Default ===
# ARGUS_LLM_DEFAULT_MODEL=llama3.2:3b

# === Ollama (free, local) ===
# ARGUS_OLLAMA_BASE_URL=http://localhost:11434
# ARGUS_OLLAMA_MODEL=llama3.2:3b
# ARGUS_OLLAMA_TIMEOUT_SECONDS=120

# === Groq (free tier) ===
# ARGUS_GROQ_API_KEY=
# ARGUS_GROQ_MODEL=llama-3.1-8b-instant
# ARGUS_GROQ_BASE_URL=https://api.groq.com/openai/v1
# ARGUS_GROQ_TIMEOUT_SECONDS=60

# === OpenRouter (paid fallback) ===
# ARGUS_OPENROUTER_API_KEY=
# ARGUS_OPENROUTER_MODEL=mistralai/mixtral-8x7b-instruct
# ARGUS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ARGUS_OPENROUTER_TIMEOUT_SECONDS=60

# === OpenAI-compatible endpoint (generic) ===
# ARGUS_OPENAI_COMPATIBLE_API_KEY=
# ARGUS_OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
# ARGUS_OPENAI_COMPATIBLE_BASE_URL=
# ARGUS_OPENAI_COMPATIBLE_TIMEOUT_SECONDS=60

# === Budget ===
# ARGUS_BUDGET_PER_RESEARCH=0.50

# === Cache TTLs (seconds) ===
# ARGUS_LLM_CACHE_TTL=86400
# ARGUS_SOURCE_CACHE_TTL=604800
# ARGUS_SEARCH_CACHE_TTL=3600

# === Vector ===
# ARGUS_VECTOR_EMBEDDING_MODEL=all-MiniLM-L6-v2
# ARGUS_VECTOR_HNSW_EF_CONSTRUCTION=200
# ARGUS_VECTOR_HNSW_M=16

# === Agent ===
# ARGUS_AGENT_CONCURRENCY=2
# ARGUS_AGENT_HEARTBEAT_TTL=30
# ARGUS_AGENT_SHUTDOWN_TIMEOUT_SECONDS=30

# === Redis Streams ===
# ARGUS_REDIS_STREAM_MAXLEN=10000
# ARGUS_REDIS_CONSUMER_GROUP=argus-workers

# === Research ===
# ARGUS_RESEARCH_MAX_DURATION_MINUTES=360
# ARGUS_RESEARCH_IDLE_TIMEOUT_MINUTES=30

# === LLM Retry ===
# ARGUS_LLM_RETRY_MAX_ATTEMPTS=3
# ARGUS_LLM_RETRY_MIN_WAIT_SECONDS=1.0
# ARGUS_LLM_RETRY_MAX_WAIT_SECONDS=10.0

# === Circuit Breaker ===
# ARGUS_CIRCUIT_BREAKER_FAIL_MAX=5
# ARGUS_CIRCUIT_BREAKER_RESET_TIMEOUT_SECONDS=30

# === Search Providers ===
# ARGUS_SERPAPI_API_KEY=
# ARGUS_FIRECRAWL_API_KEY=
# ARGUS_FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# === DuckDuckGo ===
# ARGUS_DDG_RATE_LIMIT_PER_SECOND=1.0
